<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================= -->
    <!--  LOCATION                                                     -->
    <!--  FINE is required for high-accuracy GPS, for Wi-Fi scan       -->
    <!--  results, and (pre-S) for BLE scanning.                       -->
    <!-- ============================================================= -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Allows logging to continue with the screen off / app backgrounded.
         Must be granted SEPARATELY by the user from app settings ("Allow all
         the time"). Optional for Phase 1 — a started foreground service keeps
         running while-in-use without it. -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- ============================================================= -->
    <!--  WI-FI                                                        -->
    <!-- ============================================================= -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- Required to call WifiManager.startScan(). -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <!-- API 33+: lets us trigger Wi-Fi scans. We do NOT set
         "neverForLocation" because this app legitimately derives location
         context from Wi-Fi observations. -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" />

    <!-- ============================================================= -->
    <!--  BLUETOOTH (BLE)                                              -->
    <!-- ============================================================= -->
    <!-- API 31+ runtime permissions. NOTE: we intentionally omit
         android:usesPermissionFlags="neverForLocation" because BLE
         observations are correlated with GPS in this app. -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Legacy Bluetooth permissions for API <= 30. -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />

    <!-- ============================================================= -->
    <!--  FOREGROUND SERVICE                                           -->
    <!--  Android 14 (API 34) requires a type-specific permission for  -->
    <!--  every declared foregroundServiceType.                        -->
    <!-- ============================================================= -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- API 33+: required to post the persistent service notification. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Hardware feature hints (not hard requirements, so the build still
         installs broadly). -->
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />
    <uses-feature android:name="android.hardware.wifi" android:required="false" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="ARAWN"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ARAWN"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ARAWN">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The foregroundServiceType MUST list every type the service can
             promote itself to. We combine 'location' (GPS) and
             'connectedDevice' (BLE scanning per the spec). -->
        <service
            android:name=".WirelessScannerService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location|connectedDevice" />

    </application>

</manifest>
