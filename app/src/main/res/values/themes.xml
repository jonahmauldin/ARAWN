<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Activity-level theme referenced by AndroidManifest.xml. The actual
         Compose styling lives in MainActivity (ArawnTheme); this just gives the
         window a dark, edge-to-edge AMOLED-black base before Compose draws. -->
    <style name="Theme.ARAWN" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
